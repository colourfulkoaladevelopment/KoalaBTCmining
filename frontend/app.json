{
  "expo": {
    "name": "Koala Mining",
    "slug": "koala-mining",
    "version": "1.0.0",
    "scheme": "koalamining",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "koala-mining",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.koalamining.app",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This app uses ads to provide free mining bonuses.",
        "GADApplicationIdentifier": "ca-app-pub-5648720019902247~5985575029",
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork"
          }
        ]
      }
    },
    "android": {
      "package": "com.koalamining.app",
      "versionCode": 25,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-5648720019902247~5985575029"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withAdMobFix",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5648720019902247~5985575029",
          "iosAppId": "ca-app-pub-5648720019902247~5985575029",
          "userTrackingPermission": "This app uses ads to provide free mining rewards and bonuses."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5b1a9c1-2d70-4bf8-859d-c3d4df2af944"
      }
    }
  }
}
