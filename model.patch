--------------------------------------+            miners_collection.insert_one(new_miner)
--------------------------------------+            
--------------------------------------+            # Update order status
--------------------------------------+            db.paypal_orders.update_one(
--------------------------------------+                {"_id": order_id},
--------------------------------------+                {"$set": {
--------------------------------------+                    "status": "completed",
--------------------------------------+                    "captured_at": datetime.utcnow(),
--------------------------------------+                    "miner_id": new_miner["_id"],
