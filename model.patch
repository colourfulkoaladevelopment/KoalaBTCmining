-------------------------------------------------------------------+                expected_balance = initial_balance + transaction_data['amount']
-------------------------------------------------------------------+                
-------------------------------------------------------------------+                if abs(updated_balance - expected_balance) < 0.00000001:  # Account for floating point precision
