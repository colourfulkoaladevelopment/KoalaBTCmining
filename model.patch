-------------------------------------------------------------------+    print(f"📊 Total: {total}")
-------------------------------------------------------------------+    
-------------------------------------------------------------------+    success_rate = (passed / total) * 100
-------------------------------------------------------------------+    print(f"📈 Success Rate: {success_rate:.1f}%")
-------------------------------------------------------------------+    
-------------------------------------------------------------------+    if success_rate >= 90:
-------------------------------------------------------------------+        print("🎉 Excellent! Business logic is working well.")
-------------------------------------------------------------------+    elif success_rate >= 70:
